PORT=8081
EMAIL_PROVIDER=brevo
EMAIL_FROM=support@digioffice.shop
WEBHOOK_SECRET=replace_me

# Public GA4 web stream id used by the frontend tag and server-side Measurement Protocol.
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# GA4 Measurement Protocol secret for server-confirmed events like signup, checkout, and purchase.
GA4_API_SECRET=replace_me

# Optional GA4 property id for future Data API queries inside the dashboard reporting layer.
GOOGLE_ANALYTICS_PROPERTY_ID=123456789

# Optional Search Console site url for dashboard SEO reporting.
GOOGLE_SEARCH_CONSOLE_SITE_URL=https://madeforthis.web.app/

# Optional Google service account values for future GA4 Data API and Search Console API access.
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----\n"

# Stripe secret key for richer sales reporting if you want to query Stripe directly later.
STRIPE_SECRET_KEY=sk_live_replace_me

# Brevo powers contact creation, welcome email, and transactional sends.
BREVO_API_KEY=xkeysib_replace_me
BREVO_SENDER_EMAIL=support@digioffice.shop
BREVO_SENDER_NAME=Made For This
BREVO_CONTACT_FOLDER_NAME=Tier 4 Clients

# Metricool requires the API token plus the account user id and brand id for live reporting.
METRICOOL_API_KEY=replace_me
METRICOOL_USER_ID=replace_me
METRICOOL_BLOG_ID=replace_me

# Optional cache duration for dashboard rollups in milliseconds.
DASHBOARD_CACHE_MS=300000
